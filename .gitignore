# Build output
build/
cmake-build-*/

# Database — never commit
*.db
*.db-shm
*.db-wal

# Python
__pycache__/
*.pyc
.venv/
*.pkl
*.zip

# Logs — runtime only
logs/*.log

# Config with real values
config/settings.json

# Model files — too large for git
models/saved/*.pkl
models/saved/*.zip

# macOS
.DS_Store
